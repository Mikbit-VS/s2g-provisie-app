{
  "name": "provisie-berekening",
  "version": "0.0.1",
  "private": true,
  "description": "Minimale Electron + React basis voor Provisie berekening",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:client\" \"npm:dev:electron\"",
    "dev:client": "vite --config client/vite.config.js",
    "dev:electron": "wait-on tcp:5173 && electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.0.0",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  }
}
